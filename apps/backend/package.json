{
  "name": "livestream-ecommerce",
  "version": "1.0.0",
  "main": "server.js",
  "license": "MIT",
  "type": "module",
  "imports": {
    "#*": "./src/*"
  },
  "scripts": {
    "test": "cross-env NODE_ENV=test NODE_OPTIONS=--experimental-vm-modules jest --config jest.config.cjs --runInBand",
    "test:watch": "cross-env NODE_ENV=test NODE_OPTIONS=--experimental-vm-modules jest --config jest.config.cjs --watch --runInBand",
    "test:cov": "cross-env NODE_ENV=test NODE_OPTIONS=--experimental-vm-modules jest --config jest.config.cjs --coverage --runInBand",
    "dev": "cross-env NODE_ENV=dev nodemon -e js,json,lua server.js",
    "pro": "cross-env NODE_ENV=pro node server.js",
    "swagger": "node src/config/swagger.config.js"
  },
  "dependencies": {
    "@elastic/elasticsearch": "8",
    "accesscontrol": "^2.2.1",
    "agora-token": "^2.0.5",
    "amqplib": "^1.0.3",
    "axios": "^1.15.0",
    "bcrypt": "^6.0.0",
    "chalk": "^5.6.2",
    "cloudinary": "^2.9.0",
    "cookie-parser": "^1.4.7",
    "cross-env": "^10.1.0",
    "crypto": "^1.0.1",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "fs": "^0.0.1-security",
    "http-status-codes": "^2.3.0",
    "joi": "^18.1.2",
    "jsonwebtoken": "^9.0.3",
    "lodash": "^4.17.23",
    "moment": "^2.30.1",
    "mongoose": "^9.3.3",
    "morgan": "^1.10.1",
    "ms": "^2.1.3",
    "multer": "^2.1.1",
    "multer-storage-cloudinary": "^4.0.0",
    "nanoid": "^5.1.7",
    "nodemailer": "^8.0.4",
    "path": "^0.12.7",
    "qs": "^6.15.1",
    "redis": "^5.11.0",
    "slugify": "^1.6.8",
    "socket.io": "^4.8.3",
    "swagger-autogen": "^2.23.7",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^13.0.0",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0"
