services:
  frontend:
    image: nguyennan12/novalive-frontend:latest
    container_name: novalive-frontend
    ports:
      - "80:80"
    restart: unless-stopped
    networks:
      - livestream-ecommerce-network

  backend:
    image: nguyennan12/novalive-backend:latest
    container_name: novalive-backend
    ports:
      - "3031:3031"
    env_file:
      - .env
    depends_on:
      redis:
        condition: service_healthy
      rabbitmq:
        condition: service_healthy
    restart: unless-stopped
    networks:
      - livestream-ecommerce-network

  mongodb_db:
    image: mongo:8.0
    container_name: mongodb
    networks:
      - livestream-ecommerce-network
    volumes:
      - mongo_data:/data/db
    command: [ "mongod", "--bind_ip_all" ]
    healthcheck:
      test: [ "CMD", "mongosh", "--eval", "db.adminCommand('ping')" ]
      interval: 20s
    restart: unless-stopped

  redis:
    image: redis:7-alpine
    container_name: redis
    networks:
      - livestream-ecommerce-network
    volumes:
      - redis_data:/data
    healthcheck:
      test: [ "CMD", "redis-cli", "ping" ]
      interval: 20s
    restart: unless-stopped

  rabbitmq:
    image: rabbitmq:3-management-alpine
    container_name: rabbitmq
    ports:
      - "15672:15672"
    environment:
      - RABBITMQ_DEFAULT_USER=${RABBITMQ_USER_NAME:-guest}
      - RABBITMQ_DEFAULT_PASS=${RABBITMQ_PASSWORD}
    volumes:
      - rabbitmq_data:/var/lib/rabbitmq
    networks:
      - livestream-ecommerce-network
    healthcheck:
      test: [ "CMD", "rabbitmq-diagnostics", "-q", "ping" ]
      interval: 20s
    restart: unless-stopped

  elasticsearch:
    image: docker.elastic.co/elasticsearch/elasticsearch:8.12.0
    container_name: elasticsearch
    environment:
      - node.name=elasticsearch
      - discovery.type=single-node
      - xpack.security.enabled=false
      - "ES_JAVA_OPTS=-Xms512m -Xmx512m"
    networks:
      - livestream-ecommerce-network
    restart: unless-stopped

networks:
  livestream-ecommerce-network:
    driver: bridge

volumes:
  mongo_data:
  rabbitmq_data:
  redis_data: